<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:gravity="center"
        android:height="72dp"
        android:width="72dp">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="#FFF8F0" />
        </shape>
    </item>
    <item
        android:gravity="center"
        android:height="52dp"
        android:left="12dp"
        android:right="12dp"
        android:width="52dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#E2D3BF" />
        </shape>
    </item>
    <item
        android:gravity="center"
        android:height="40dp"
        android:width="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#8E5E3B" />
        </shape>
    </item>
</layer-list>

